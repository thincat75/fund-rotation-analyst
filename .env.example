# Recommended authenticated enhancement: official Tushare Pro.
TUSHARE_PROVIDER=official
TUSHARE_TOKEN=replace_with_your_own_token

# Third-party compatibility mode uses a proxy-issued credential, not an official token.
# TUSHARE_PROVIDER=third-party-proxy
# TUSHARE_TOKEN=replace_with_proxy_issued_credential
# TUSHARE_HTTP_URL=http://cheap-host1.cheapyun.com:24145
